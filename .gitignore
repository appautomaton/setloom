.DS_Store
.env
.env.*
!.env.example

__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
.cache/

# Claude Code: session-local config and worktrees (never committed). Shared
# .claude/settings.json and any .claude/skills, hooks, or commands stay tracked.
.claude/settings.local.json
.claude/worktrees/

node_modules/
dist/
build/

# Machine-local material: corpus audio (copyrighted, never committed),
# separation caches, analysis dossiers, candidates, release packages.
/local/

# Disposable scratch experiments. Never committed.
/tmp/

# Model weights store (HF_HUB_CACHE target). Never committed.
/models/

# Read-only reference clones of upstream projects; local working aid only.
/.references/

# Audio renders: large, binary, often copyrighted — never committed anywhere.
*.wav
*.aiff
*.aif
*.flac
*.mp3

# MIDI is small, regenerable source material — committable as track input.
# Machine-local MIDI (candidates, scratch) is already covered by /local/ above.
